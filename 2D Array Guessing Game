import java.util.Scanner;
public class Guess2DArray {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the dimensions of the array (rows x columns) : ");
		int rows = sc.nextInt();
		int columns = sc.nextInt();
		int[][] arr = new int[rows][columns];
		for (int i = 0; i < arr.length; i++) {
			for (int j = 0; j < arr[i].length; j++) {
				int num = (int)(Math.random() * 20) + 1;
				arr[i][j] = num;
			}
		}
		int max = arr[0][0];
		int min = arr[0][0];
		for (int k = 0; k < arr.length; k++) {
			for (int l = 0; l < arr[k].length; l++) {
				if (arr[k][l] > max)
					max = arr[k][l];
				else if (arr[k][l] < min)
					min = arr[k][l];
			}
		}
		boolean maxCorrect = false;
		boolean minCorrect = false;
		while (!maxCorrect || !minCorrect) {
			if (!maxCorrect) {
				System.out.println("Guess the largest number: ");
				int maxGuess = sc.nextInt();
				if (maxGuess == max) {
					maxCorrect = true;
					System.out.println("Correct! " + max + " is the largest number.");
				}
				else
					System.out.println("Incorrect! You will need to guess again.");
			}
			if (!minCorrect) {
				System.out.println("Guess the smallest number: ");
				int minGuess = sc.nextInt();
				if (minGuess == min) {
					minCorrect = true;
					System.out.println("Correct! " + min + " is the smallest number.");
				}
				else
					System.out.println("Incorrect! You will need to guess again.");
			}
		}
		System.out.println("Good job! Game over!");
	}
}
