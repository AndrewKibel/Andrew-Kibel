package game2048;

import java.awt.*;
import javax.swing.*;

public class GameBoard extends JPanel {

    private Board board; // model for the game
    private static final int TILE_SIZE = 106; // size of each tile
    private static final int TILE_GAP = 15; // space between each tile
    private static final int PADDING = 15; // space between the board and the edge of the view
    private static final int ARC_RADIUS = 12; // radius of rounded tile edges,
                                             // to appear like actual 2048
    private static final int GRID_SIZE = 4; // size of the 4x4 2048 grid
    private static final Font FONT = new Font("SansSerif", Font.BOLD, 36);
                                        // font with which to write numbers on tiles

    public GameBoard(Board board) {
        this.board = board;
        setBackground(new Color(0xBBADA0));
        setPreferredSize(new Dimension(500, 500));
    }

    /**
     * Overridden paint component method that paints the current 2048 board
     * to look like the actual game
     * @param g the <code>Graphics</code> object to protect
     */
    @Override
    public void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setColor(new Color(0xBBADA0));
        g2.fillRect(0, 0, getWidth(), getHeight());
        int sideLength = GRID_SIZE * TILE_SIZE + (GRID_SIZE - 1) * TILE_GAP;
        int startX = (getWidth() - sideLength) / 2;
        int startY = (getHeight() - sideLength) / 2;
        startX = Math.max(startX, PADDING);
        startY = Math.max(startY, PADDING);
        for (int row = 0; row < GRID_SIZE; row++) {
            for (int col = 0; col < GRID_SIZE; col++) {
                int value = board.getTile(row, col);
                int x = startX + col * (TILE_SIZE + TILE_GAP);
                int y = startY + row * (TILE_SIZE + TILE_GAP);
                g2.setColor(getTileColor(value));
                g2.fillRoundRect(x, y, TILE_SIZE, TILE_SIZE, ARC_RADIUS, ARC_RADIUS);
                if (value != 0) {
                    g2.setColor(getTextColor(value));
                    g2.setFont(FONT);
                    String number = Integer.toString(value);
                    FontMetrics fm = g2.getFontMetrics();
                    int textWidth = fm.stringWidth(number);
                    int textHeight = fm.getAscent() + fm.getDescent();
                    int textX = x + (TILE_SIZE - textWidth) / 2;
                    int textY = y + (TILE_SIZE - textHeight) / 2 + fm.getAscent();
                    g2.drawString(number, textX, textY);
                }
            }
        }
    }

    public void setBoard(Board board) {
        this.board = board;
    }

    /**
     * Helper method to return the color of the tile associated with a given value
     * @param value of the tile
     * @return color of the tile
     */
    private Color getTileColor(int value) {
        return switch (value) {
            case 0 -> new Color(0xCDC1B4);
            case 2 -> new Color(0xEEE4DA);
            case 4 -> new Color(0xEDE0C8);
            case 8 -> new Color(0xF2B179);
            case 16 -> new Color(0xF59563);
            case 32 -> new Color(0xF67C5F);
            case 64 -> new Color(0xF65E3B);
            case 128 -> new Color(0xEDCF72);
            case 256 -> new Color(0xEDCC61);
            case 512 -> new Color(0xEDC850);
            case 1024 -> new Color(0xEDC53F);
            case 2048 -> new Color(0xEDC22E);
            default -> new Color(0x3C3A32);
        };
    }

    /**
     * Helper method to return the color of the text to put in a tile to write the value associated
     * with it, necessary because tiles <= 4 are light and all others are dark
     * @param value of the tile
     * @return color of text in the tile
     */
    private Color getTextColor(int value) {
        if (value <= 4) {
            return Color.BLACK;
        } else {
            return Color.WHITE;
        }
    }

    /**
     * Overridden method
     * @return preferred size of board
     */
    @Override
    public Dimension getPreferredSize() {
        return new Dimension(500, 500);
    }
}

package game2048;

import java.awt.*;
import java.awt.event.*;
import javax.swing.*;
import java.io.*;
import java.util.ArrayDeque;
import java.util.Deque;
import java.util.Scanner;

public class Run2048 implements Runnable {

    private static final String SAVE_FILE = "2048_save.txt"; // file that saves game state
    private static final String HIGH_SCORE_FILE = "2048_high_score.txt";
                                    // file that saves the high score
    private static final String UNDO_STACK_FILE = "2048_undo_stack.txt";
    private JFrame frame; // JFrame
    private Board board; //  model for the game
    private GameBoard gameBoard; // view for the game
    private JLabel status; // shows score or game over
    private JLabel highScoreLabel; // shows high score
    private int highScore; // all-time high score of the user
    private Deque<Board> undoStack; // stack of previous boards from the game for undo feature

    /**
     * Overridden run method, which actually runs the game
     */
    @Override
    public void run() {
        board = new Board();
        undoStack = new ArrayDeque<>();
        frame = new JFrame("2048");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        status = new JLabel("Join the numbers and get to the 2048 tile!", SwingConstants.CENTER);
        highScoreLabel = new JLabel("High Score: 0", SwingConstants.CENTER);
        gameBoard = new GameBoard(board);
        JPanel controlPanel = new JPanel();
        controlPanel.setLayout(new GridLayout(2, 1));
        controlPanel.add(status);
        controlPanel.add(highScoreLabel);
        JButton newGameButton = new JButton("New Game");
        JButton undoButton = new JButton("Undo");
        JButton saveQuitButton = new JButton("Save & Quit");
        controlPanel.add(newGameButton);
        controlPanel.add(undoButton);
        controlPanel.add(saveQuitButton);
        JPanel messagePanel = new JPanel();
        messagePanel.setLayout(new GridLayout(1, 1));
        messagePanel.add(new JLabel("Join the numbers and get to the 2048 tile!",
                SwingConstants.CENTER));
        frame.add(gameBoard, BorderLayout.CENTER);
        frame.add(controlPanel, BorderLayout.NORTH);
        frame.add(messagePanel, BorderLayout.SOUTH);
        newGameButton.addActionListener(e -> startNewGame());
        undoButton.addActionListener(e -> undo());
        saveQuitButton.addActionListener(e -> {
            saveGame();
            frame.dispose();
        });
        KeyAdapter keyAdapter = new KeyAdapter() {
            @Override
            public void keyPressed(KeyEvent e) {
                char move = 0;
                int code = e.getKeyCode();
                if (code == KeyEvent.VK_UP || code == KeyEvent.VK_W) {
                    move = 'w';
                } else if (code == KeyEvent.VK_DOWN || code == KeyEvent.VK_S) {
                    move = 's';
                } else if (code == KeyEvent.VK_LEFT || code == KeyEvent.VK_A) {
                    move = 'a';
                } else if (code == KeyEvent.VK_RIGHT || code == KeyEvent.VK_D) {
                    move = 'd';
                }
                if (move != 0) {
                    handleMove(move);
                }
            }
        };
        gameBoard.addKeyListener(keyAdapter);
        gameBoard.setFocusable(true);
        gameBoard.requestFocusInWindow();
        loadHighScore();
        updateHighScoreLabel();
        if (!loadGameIfExists()) {
            startNewGame();
        }
        frame.pack();
        frame.setLocationRelativeTo(null);
        frame.setVisible(true);
    }

    /**
     * Starts a new 2048 game according to the rules of 2048
     */
    private void startNewGame() {
        board.resetBoard();
        undoStack.clear();
        board.placeRandomTile();
        board.placeRandomTile();
        updateStatusLabel();
        gameBoard.repaint();
        gameBoard.requestFocusInWindow();
    }

    /**
     * Handles a single move of the user, attempts it,
     * pushes the old board to undo stack if the board changes,
     * places a random tile, and checks if the game is over
     * @param move that was made
     */
    private void handleMove(char move) {
        Board before = new Board(board);
        boolean changed = switch (move) {
            case 'w' -> board.moveUp();
            case 's' -> board.moveDown();
            case 'a' -> board.moveLeft();
            case 'd' -> board.moveRight();
            default -> false;
        };
        if (changed) {
            undoStack.push(before);
            board.placeRandomTile();
        }
        updateStatusLabel();
        gameBoard.repaint();
        if (board.noMovesLeft()) {
            JOptionPane.showMessageDialog(frame, "Game over! Final Score: " + board.getScore(),
                    "Game Over", JOptionPane.INFORMATION_MESSAGE);
        }
        gameBoard.requestFocusInWindow();
    }

    /**
     * Undoes the last move and restores the previous board to the game
     */
    private void undo() {
        if (!undoStack.isEmpty()) {
            board = undoStack.pop();
            gameBoard.setBoard(board);
            updateStatusLabel();
            gameBoard.repaint();
        } else {
            JOptionPane.showMessageDialog(frame, "No moves to undo.",
                    "Undo",  JOptionPane.INFORMATION_MESSAGE);
        }
        gameBoard.requestFocusInWindow();
    }

    /**
     * Updates the status label to display the score and if the game is over
     */
    private void updateStatusLabel() {
        int currentScore = board.getScore();
        if (currentScore > highScore) {
            highScore = currentScore;
            saveHighScore();
        }
        if (board.noMovesLeft()) {
            status.setText("Game Over! Final Score: " + board.getScore());
        } else {
            status.setText("Score: " + board.getScore());
        }
        updateHighScoreLabel();
    }

    /**
     * Saves the current game state to a file, including the score
     * and the full board and saves the undo stack of the current game to a separate file
     */
    private void saveGame() {
        try (PrintWriter out = new PrintWriter(new FileWriter(SAVE_FILE))) {
            out.println(board.getScore());
            for (int row = 0; row < Board.SIZE; row++) {
                for (int col = 0; col < Board.SIZE; col++) {
                    out.print(board.getTile(row, col));
                    if (col < Board.SIZE - 1) {
                        out.print(" ");
                    }
                }
                out.println();
            }
        } catch (IOException e) {
            JOptionPane.showMessageDialog(frame, "Error saving game: " + e.getMessage(),
                    "Save Error", JOptionPane.ERROR_MESSAGE);
        } finally {
            try (PrintWriter out = new PrintWriter(new FileWriter(UNDO_STACK_FILE))) {
                int numBoards = undoStack.size();
                out.println(numBoards);
                if (numBoards > 0) {
                    for (Board board : undoStack) {
                        out.println(board.getScore());
                        for (int i = 0; i < Board.SIZE; i++) {
                            for (int j = 0; j < Board.SIZE; j++) {
                                out.print(board.getTile(i, j));
                                if (j < Board.SIZE - 1) {
                                    out.print(" ");
                                }
                            }
                            out.println();
                        }
                    }
                }
            } catch (IOException e) {
                JOptionPane.showMessageDialog(frame, "Error saving undo stack" + e.getMessage(),
                        "Save Error", JOptionPane.ERROR_MESSAGE);
            }
        }
    }

    /**
     * Upon starting the game, asks the user if they want to load
     * the previous game if the file exists and actually loads that
     * game if desired, setting the current board to the saved board
     * and the undo stack to the saved undo stack
     * @return if a previous game file was loaded
     */
    private boolean loadGameIfExists() {
        File saveFile = new File(SAVE_FILE);
        File undoFile = new File(UNDO_STACK_FILE);
        if (!saveFile.exists()) {
            return false;
        }
        int option = JOptionPane.showConfirmDialog(frame,
                "Do you want to load your previous saved game?",
                "Load Saved Game", JOptionPane.YES_NO_OPTION);
        if (option != JOptionPane.YES_OPTION) {
            return false;
        }
        try (Scanner sc = new Scanner(saveFile)) {
            int savedScore = sc.nextInt();
            Board loadedBoard = new Board();
            loadedBoard.setScore(savedScore);
            for (int row = 0; row < Board.SIZE; row++) {
                for (int col = 0; col < Board.SIZE; col++) {
                    int value = sc.nextInt();
                    loadedBoard.setTile(row, col, value);
                }
            }
            board = loadedBoard;
            undoStack.clear();
            try (Scanner sc2 = new Scanner(undoFile)) {
                int numBoards = sc2.nextInt();
                if (numBoards > 0) {
                    for (int x = 0; x < numBoards; x++) {
                        Board loadedUndoBoard = new Board();
                        int loadedScore = sc2.nextInt();
                        for (int r = 0; r < Board.SIZE; r++) {
                            for (int c = 0; c < Board.SIZE; c++) {
                                int val = sc2.nextInt();
                                loadedUndoBoard.setTile(r, c, val);
                            }
                        }
                        loadedUndoBoard.setScore(loadedScore);
                        undoStack.add(loadedUndoBoard);
                    }
                }
            } catch (IOException e) {
                JOptionPane.showMessageDialog(frame,
                        "Error loading undo stack. Game will be played without undo stack.",
                        "Load error", JOptionPane.ERROR_MESSAGE);
            }
            gameBoard.setBoard(board);
            updateStatusLabel();
            gameBoard.repaint();
            gameBoard.requestFocusInWindow();
            return true;
        } catch (IOException e) {
            JOptionPane.showMessageDialog(frame, "Error loading saved game. New game will start.",
                    "Load error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
    }

    /**
     * Loads the user's all-time high score from the file
     */
    private void loadHighScore() {
        File file = new File(HIGH_SCORE_FILE);
        if (!file.exists()) {
            highScore = 0;
            return;
        }
        try (Scanner sc = new Scanner(file)) {
            if (sc.hasNextInt()) {
                highScore = sc.nextInt();
            } else {
                highScore = 0;
            }
        } catch (IOException e) {
            highScore = 0;
        }
    }

    /**
     * Saves the current high score to the file
     */
    private void saveHighScore() {
        try (PrintWriter out = new PrintWriter(new FileWriter(HIGH_SCORE_FILE))) {
            out.println(highScore);
        } catch (IOException e) {
            JOptionPane.showMessageDialog(frame, "Error saving high score",
                    "Error",  JOptionPane.ERROR_MESSAGE);
        }
    }

    /**
     * Updates the high score label to display the new high score
     */
    private void updateHighScoreLabel() {
        highScoreLabel.setText("High Score: " + highScore);
    }
}

package game2048;

import java.util.Random;
import java.util.Arrays;
import java.util.Scanner;

public class Board {

    private int[][] board; // current 2048 board
    private int score; // current score of game
    public static final int SIZE = 4; // size of 2048 board, unchangeable

    /**
     * Constructs the empty 2048 board and initializes the score
     */
    public Board() {
        board = new int[SIZE][SIZE];
        score = 0;
    }

    /**
     * Constructs a 2048 board equivalent to the current game state, so that
     * it can be added to the deque of previous boards so that the undo board
     * functionality be fulfilled
     * @param previous board of previous game state
     */
    public Board(Board previous) {
        board = new int[SIZE][SIZE];
        for (int i = 0; i < SIZE; i++) {
            board[i] = previous.getBoard()[i].clone();
        }
        score = previous.getScore();
    }

    /**
     * @return current 2048 board
     */
    public int[][] getBoard() {
        return board;
    }

    /**
     * @return current score
     */
    public int getScore() {
        return score;
    }

    /**
     * Sets the current score to a given score
     * @param score to set
     */
    public void setScore(int score) {
        this.score = score;
    }

    /**
     * @param row of tile to be returned
     * @param col of tile to be returned
     * @return tile at index row, col
     */
    public int getTile(int row, int col) {
        return board[row][col];
    }

    /**
     * Sets tile at a given index to a given value
     * @param row of tile
     * @param col of tile
     * @param value of tile
     */
    public void setTile(int row, int col, int value) {
        board[row][col] = value;
    }

    /**
     * Resets board to a default board so that a new game can be played
     * and resets the current score to 0
     */
    public void resetBoard() {
        board = new int[SIZE][SIZE];
        score = 0;
    }

    /**
     * Places random tile on an empty space on the board
     * Occurs after every turn and twice at the beginning of the game
     * 90% probability that the tile is a 2, 10% that it is a 4
     * @return if a tile is able to be placed
     */
    public void placeRandomTile() {
        int count0 = 0;
        for (int i = 0; i < SIZE; i++) {
            for (int j = 0; j < SIZE; j++) {
                if (board[i][j] == 0) {
                    count0++;
                }
            }
        }
        Random random = new Random();
        int newTile = 0;
        if (random.nextInt(10) + 1 == 10) {
            newTile = 4;
        } else {
            newTile = 2;
        }
        int place = random.nextInt(count0) + 1;
        int count = 0;
        boolean done = false;
        for (int i = 0; i < SIZE && !done; i++) {
            for (int j = 0; j < SIZE; j++) {
                if (board[i][j] == 0) {
                    count++;
                    if (count == place) {
                        board[i][j] = newTile;
                        done = true;
                        break;
                    }
                }
            }
        }
    }

    /**
     * Adjusts the entire board following a right swipe according to the 2048 rules,
     * merging tiles as necessary
     * @return if any changes were made to the board
     */
    public boolean moveRight() {
        int[][] oldBoard = copyBoard(board);
        int[] slidRow;
        for (int i = 0; i < SIZE; i++) {
            slidRow = compressRow(board[i]);
            for (int j = SIZE - 1; j > 0; j--) {
                if (slidRow[j] != 0 && slidRow[j] == slidRow[j - 1]) {
                    slidRow[j] *= 2;
                    score += slidRow[j];
                    slidRow[j - 1] = 0;
                    j--;
                }
            }
            slidRow = compressRow(slidRow);
            board[i] = slidRow;
        }
        return !Arrays.deepEquals(oldBoard, board);
    }

    /**
     * Adjusts the entire board following a left swipe according to the 2048 rules,
     * merging tiles as necessary
     * @return if any changes were made to the board
     */
    public boolean moveLeft() {
        for (int i = 0; i < SIZE; i++) {
            board[i] = reverseRow(board[i]);
        }
        boolean changed = moveRight();
        for (int j = 0; j < SIZE; j++) {
            board[j] = reverseRow(board[j]);
        }
        return changed;
    }

    /**
     * Adjusts the entire board following an up swipe according to the 2048 rules,
     * merging tiles as necessary
     * @return if any changes were made to the board
     */
    public boolean moveUp() {
        rotate90CW();
        boolean changed = moveRight();
        rotate90CCW();
        return changed;
    }

    /**
     * Adjusts the entire board following a down swipe according to the 2048 rules,
     * merging tiles as necessary
     * @return if any changes were made to the board
     */
    public boolean moveDown() {
        rotate90CCW();
        boolean changed = moveRight();
        rotate90CW();
        return changed;
    }

    /**
     * Moves all the tiles of a row to the right without merging them
     * @param row to be compressed
     * @return the compressed row
     */
    private int[] compressRow(int[] row) {
        int[] compressedRow = new int[SIZE];
        int index = SIZE - 1;
        for (int j = SIZE - 1; j >= 0; j--) {
            if (row[j] != 0) {
                compressedRow[index] = row[j];
                index--;
            }
        }
        return compressedRow;
    }

    /**
     * Reverses a 1d array so that it can be moved by moveRowRight for different swiping directions
     * @param row to be reversed
     * @return reversed 1d array
     */
    private int[] reverseRow(int[] row) {
        int[] reverseRow = new int[SIZE];
        int index = SIZE - 1;
        for (int j = 0; j < SIZE; j++) {
            reverseRow[j] =  row[index];
            index--;
        }
        return reverseRow;
    }

    /**
     * Rotates a 4x4 board 90 degrees clockwise, necessary for moving up and down
     */
    private void rotate90CW() {
        int[][] newBoard = new int[SIZE][SIZE];
        for (int i = 0; i < SIZE; i++) {
            int index = SIZE - 1;
            for (int j = 0; j < SIZE; j++) {
                newBoard[i][j] = board[index][i];
                index--;
            }
        }
        board = newBoard;
    }

    /**
     * Rotates a 4x4 board 90 degrees counterclockwise, necessary for moving up and down
     */
    private void rotate90CCW() {
        int[][] newBoard = new int[SIZE][SIZE];
        int index = SIZE - 1;
        for (int i = 0; i < SIZE; i++) {
            for (int j = 0; j < SIZE; j++) {
                newBoard[i][j] = board[j][index];
            }
            index--;
        }
        board = newBoard;
    }

    /**
     * Checks if there are any adjacent equal tiles, which indicates remaining possible moves
     * @return if there are any possible moves left
     */
    public boolean noMovesLeft() {
        for (int i = 0; i < SIZE; i++) {
            for (int j = 0; j < SIZE; j++) {
                if (board[i][j] == 0) {
                    return false;
                }
            }
        }
        for (int row = 0; row < SIZE - 1; row++) {
            for (int col = 0; col < SIZE - 1; col++) {
                if (board[row][col] == board[row][col + 1] ||
                        board[row][col] == board[row + 1][col]) {
                    return false;
                }
            }
        }
        for (int x = 0; x < SIZE - 1; x++) {
            if (board[x][SIZE - 1] == board[x + 1][SIZE - 1]) {
                return false;
            }
        }
        for (int y = 0;  y < SIZE - 1; y++) {
            if (board[SIZE - 1][y] == board[SIZE - 1][y + 1]) {
                return false;
            }
        }
        return true;

    }

    /**
     * Copies a 2d array onto a separate 2d array
     * @param board to be copied
     * @return copy of the given board
     */
    private int[][] copyBoard(int[][] board) {
        int[][] copy = new int[SIZE][SIZE];
        for (int i = 0; i < SIZE; i++) {
            copy[i] = board[i].clone();
        }
        return copy;
    }

    /**
     * Main method to play the game in the console for testing purposes, demonstrating modularity
     * @param args
     */
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Board board = new Board();
        board.placeRandomTile();
        board.placeRandomTile();
        boolean done = false;
        while (!done) {
            for (int i = 0; i < SIZE; i++) {
                for (int j = 0; j < SIZE; j++) {
                    System.out.print(board.getTile(i, j) + "  ");
                }
                System.out.println();
            }
            System.out.println("Enter your move: ");
            String move = sc.nextLine();
            boolean changed = switch (move) {
                case "w" -> board.moveUp();
                case "a" -> board.moveLeft();
                case "s" -> board.moveDown();
                case "d" -> board.moveRight();
                default -> false;
            };
            System.out.println("Score: " + board.getScore());
            if (changed) {
                board.placeRandomTile();
            }
            done = board.noMovesLeft();
        }
        for (int i = 0; i < SIZE; i++) {
            for (int j = 0; j < SIZE; j++) {
                System.out.print(board.getTile(i, j) + "  ");
            }
            System.out.println();
        }
        System.out.println("Game Over! Final Score: " + board.getScore());
    }
}
